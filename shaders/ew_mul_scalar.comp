#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;
layout(set = 0, binding = 0) readonly buffer Buf { float in_data[]; };
layout(set = 0, binding = 1) writeonly buffer Out { float out_data[]; };
layout(push_constant) uniform Params { uint n; float scalar; } pc;
void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= pc.n) return;
    out_data[i] = in_data[i] * pc.scalar;
}
